# Public form endpoint used by the contact page.
# Set this in Vercel Project Settings -> Environment Variables.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xbdqqvjy

# Server-only email key used by /api/book-call. Do not expose this publicly.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Flux Media Creations <noreply@fluxmediacreations.com>
BOOKING_OWNER_EMAIL=contact@fluxmediacreations.com

# Optional: send booking payloads into Make, Zapier, GoHighLevel, or another CRM.
AUTOMATION_WEBHOOK_URL=

# Optional local/server booking file path. For production, replace this file store with a real DB or calendar API.
BOOKINGS_FILE_PATH=
